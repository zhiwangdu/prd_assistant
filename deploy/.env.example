# Runtime directory. This should usually be the parent directory of this deploy/ folder.
export LOGAGENT_APP_DIR="/path/to/logagent-runtime"

# Source repository used by rebuild-install.sh.
export LOGAGENT_SRC_DIR="/path/to/prd_assistant"

# Server API key used by WebUI and Native Agent.
export LOGAGENT_NATIVE_API_KEY="replace-me"

# OpenAI-compatible LLM provider.
export LOGAGENT_LLM_BASE_URL="https://example.invalid/v1"
export LOGAGENT_LLM_API_KEY="replace-me"
export LOGAGENT_LLM_MODEL="replace-me"

# Reserved for future embedding/vector recall. The default deploy config keeps
# embedding.enabled=false, so this is not required today.
# export LOGAGENT_EMBEDDING_API_KEY="replace-me"

# Claude Code command. Required by the default logagent.yaml. Usually set this
# to the absolute path printed by `which claude`.
# export LOGAGENT_CLAUDE_CODE_PATH="/abs/path/to/claude"

# Optional submodule clone URL overrides for intranet mirrors. If all four
# repositories live under one namespace, set LOGAGENT_SUBMODULE_BASE_URL;
# per-repository URLs below take precedence when set.
# export LOGAGENT_SUBMODULE_BASE_URL="ssh://git@gitlab.internal/zhiwangdu"
# export LOGAGENT_SUBMODULE_INFLUXQL_URL="ssh://git@gitlab.internal/zhiwangdu/influxql.git"
# export LOGAGENT_SUBMODULE_FLUX_URL="ssh://git@gitlab.internal/zhiwangdu/flux.git"
# export LOGAGENT_SUBMODULE_OPENGEMINI_URL="ssh://git@gitlab.internal/zhiwangdu/openGemini.git"
# export LOGAGENT_SUBMODULE_INFLUXDB_URL="ssh://git@gitlab.internal/zhiwangdu/influxdb.git"

# Optional overrides.
# export LOGAGENT_CONFIG="$LOGAGENT_APP_DIR/deploy/logagent.yaml"
# export LOGAGENT_SERVER_BIN="$LOGAGENT_APP_DIR/bin/logagent-server"
# export LOGAGENT_HEALTH_URL="http://127.0.0.1:50992/health"
# export LOGAGENT_PID_FILE="$LOGAGENT_APP_DIR/logagent-server.pid"
# export LOGAGENT_LOG_FILE="$LOGAGENT_APP_DIR/logagent-server.log"

# Optional V2 runtime overrides. V2 uses Python/FastAPI, SQLite, local artifacts,
# and serves the same WebUI build from LOGAGENT_V2_WEBUI_DIR.
# export LOGAGENT_V2_APP_DIR="$LOGAGENT_APP_DIR"
# export LOGAGENT_V2_API_KEY="$LOGAGENT_NATIVE_API_KEY"
# export LOGAGENT_V2_HOST="127.0.0.1"
# export LOGAGENT_V2_PORT="50993"
# export LOGAGENT_V2_DATA_DIR="$LOGAGENT_APP_DIR/data-v2"
# export LOGAGENT_V2_WEBUI_DIR="$LOGAGENT_APP_DIR/webui/out"
# export LOGAGENT_V2_VENV_DIR="$LOGAGENT_APP_DIR/server-v2/.venv"
# export LOGAGENT_V2_PID_FILE="$LOGAGENT_APP_DIR/logagent-v2.pid"
# export LOGAGENT_V2_LOG_FILE="$LOGAGENT_APP_DIR/logagent-v2.log"
# export LOGAGENT_V2_HEALTH_URL="http://127.0.0.1:50993/health"
# export LOGAGENT_V2_STARTUP_TIMEOUT_SECONDS=30
# export LOGAGENT_V2_DISCOVER_PROCESS=0

# Optional V2 Fetch endpoint execution boundary. Disabled by default.
# Generate LOGAGENT_V2_FETCH_SECRET_KEY with:
#   python3 - <<'PY'
#   import base64, os
#   print(base64.urlsafe_b64encode(os.urandom(32)).decode())
#   PY
# export LOGAGENT_V2_FETCH_ENABLED=1
# export LOGAGENT_V2_FETCH_ALLOWED_HOSTS="127.0.0.1,example.internal:8080"
# export LOGAGENT_V2_FETCH_TIMEOUT_SECONDS=20
# export LOGAGENT_V2_FETCH_MAX_REQUEST_BYTES=1048576
# export LOGAGENT_V2_FETCH_MAX_RESPONSE_BYTES=1048576
# export LOGAGENT_V2_FETCH_MAX_REDIRECTS=5
# export LOGAGENT_V2_FETCH_SECRET_KEY="replace-me"

# Optional V2 source-built analyzer tools. Build with:
#   deploy/rebuild-v2-install.sh --with-tools
# or:
#   deploy/rebuild-v2-install.sh --tools-only --only-tool influxql
# The default V2 runtime auto-discovers these filenames under
# $LOGAGENT_APP_DIR/bin/tools after logagent-v2ctl.sh exports LOGAGENT_V2_APP_DIR.
# Set LOGAGENT_V2_TOOLS_DIR or the per-tool variables only for custom locations.
# export LOGAGENT_V2_TOOLS_DIR="$LOGAGENT_APP_DIR/bin/tools"
# export LOGAGENT_V2_TOOL_INFLUXQL_ANALYZER="$LOGAGENT_APP_DIR/bin/tools/influxql-analyzer"
# export LOGAGENT_V2_TOOL_FLUX_QUERY_ANALYZER="$LOGAGENT_APP_DIR/bin/tools/flux_query_analyzer"
# export LOGAGENT_V2_TOOL_OPENGEMINI_STORAGE_ANALYZER="$LOGAGENT_APP_DIR/bin/tools/opengemini-storage-analyzer"
# export LOGAGENT_V2_TOOL_INFLUXDB_STORAGE_ANALYZER="$LOGAGENT_APP_DIR/bin/tools/influxdb_storage_analyzer"

# Optional V2 pprof built-in tool.
# export LOGAGENT_V2_PPROF_ENABLED=1
# export LOGAGENT_V2_PPROF_GO_COMMAND="$(command -v go)"

# Optional V2 Huawei OBS + GaussDB package sync built-in tool. Disabled by default.
# export LOGAGENT_V2_HUAWEI_PACKAGE_SYNC_ENABLED=1
# export LOGAGENT_V2_HUAWEI_OBS_ENDPOINT="https://obs.cn-north-4.myhuaweicloud.com"
# export LOGAGENT_V2_HUAWEI_OBS_BUCKET="replace-me"
# export LOGAGENT_V2_HUAWEI_OBS_OBJECT_PREFIX="packages"
# export LOGAGENT_V2_HUAWEI_OBS_ACCESS_KEY="replace-me"
# export LOGAGENT_V2_HUAWEI_OBS_SECRET_KEY="replace-me"
# export LOGAGENT_V2_HUAWEI_OBS_SECURITY_TOKEN=""
# export LOGAGENT_V2_HUAWEI_GAUSSDB_DSN="postgresql://user:password@host:port/dbname?sslmode=require"
